algoritmo "Nome do Programa"

var
nome: caractere
idade: inteiro
email: caractere
bolsa: real
experiencia: caractere
inicio
escreval("Escreva seu Nome Completo")
leia(nome)
escreval("Digite a sua Idade")
leia(idade)
escreval("Digite seu email")
leia(email)
escreval(" Digite o valor da Bolsa")
leia(bolsa)
escreval(" Possui Experiencia")
leia(experiencia)
fimalgoritmo
