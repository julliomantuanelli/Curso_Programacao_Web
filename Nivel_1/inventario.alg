algoritmo "Nome do Programa"
var
    item:caractere
inicio
    escreval(" Digite o primeiro item")
    leia(item)
    escreval(item, " Item registrado com sucesso ")
    escreval(" Digite o segundo bem")
    leia(item)
    escreval(" Bem 1 descartado e item 2 registrado ",item)
    item <- " Estoque zerado"
    escreval(item)
fimalgoritmo