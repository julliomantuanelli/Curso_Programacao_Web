algoritmo "Nome do Programa"
var
naluno: caractere
nprof: caractere
reserva: caractere
inicio
escreval("Nome do aluno")
leia(naluno)
escreval("Escreva o nome do professor ")
leia(nprof)
reserva <- naluno
naluno <- nprof
nprof <- reserva
escreva("O nome do aluno é ", naluno, " e o nome do professor ", nprof)

fimalgoritmo